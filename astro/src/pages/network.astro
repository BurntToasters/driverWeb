---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
    title="Network Drivers | DriverHub"
    metaDescription="Browse Windows network drivers with trust and compatibility filters."
    metaRobots="index, follow"
    canonical="https://driverhub.win/network"
    showSkipLink={true}
    headerVariant="main"
    navActive="network"
    showSearchButton={true}
    showFavoritesButton={true}
    showDarkModeButton={true}
    showSettings={true}
    footerVariant="full"
    scripts={['global/favorites.js', 'global/search.js', 'global/darkMode.js', 'global/regionSwitcher.js', 'global/modern.js', 'global/versionInfo.js', 'global/driverLoader.js', 'global/backToTop.js']}
>
<Fragment slot="metaExtra">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://driverhub.win/network">
    <meta property="og:title" content="Network Drivers | DriverHub">
    <meta property="og:description" content="Browse Windows network drivers with trust and compatibility filters.">
    <meta property="og:image" content="https://prod.rexxit.net/global/_icons/DH-logo-optim.webp">
    <meta property="twitter:card" content="summary">
    <meta property="twitter:title" content="Network Drivers | DriverHub">
    <meta property="twitter:description" content="Browse Windows network drivers with trust and compatibility filters.">
</Fragment>
<main id="main-content" class="flex-1 max-w-7xl mx-auto px-4 md:px-6 py-10 w-full animate-fade-in">
    <div class="mb-8">
        <h1 class="page-heading mb-2">Network Drivers</h1>
        <p class="page-subheading font-bold">Production listings for Wi-Fi and ethernet drivers with professional filtering and compare tools.</p>
    </div>

    <div class="grid lg:grid-cols-[300px_1fr] gap-8 items-start">
        <aside class="card p-5 sticky top-24 space-y-4 shadow-neo-flat dark:shadow-neo-flat-dark" data-animate>
            <h2 class="text-base font-black text-gray-900 dark:text-white uppercase tracking-wider">Filters</h2>
            <div class="space-y-1">
                <label for="filter-query-input" class="text-xs font-bold text-gray-500 uppercase">Search Notes</label>
                <input id="filter-query-input" type="text" class="w-full px-3 py-2 bg-white dark:bg-gray-900 border-[3px] border-black dark:border-white font-bold outline-none shadow-[2px_2px_0px_0px_#000] dark:shadow-[2px_2px_0px_0px_#fff] focus:-translate-x-[2px] focus:-translate-y-[2px] focus:shadow-[4px_4px_0px_0px_#000] dark:focus:shadow-[4px_4px_0px_0px_#fff] transition-all text-sm text-gray-900 dark:text-white" placeholder="Search network drivers...">
            </div>
            <div class="space-y-1">
                <label for="filter-risk-select" class="text-xs font-bold text-gray-500 uppercase">Risk Level</label>
                <select id="filter-risk-select" class="w-full px-3 py-2 bg-white dark:bg-gray-900 border-[3px] border-black dark:border-white font-bold outline-none shadow-[2px_2px_0px_0px_#000] dark:shadow-[2px_2px_0px_0px_#fff] focus:-translate-x-[2px] focus:-translate-y-[2px] focus:shadow-[4px_4px_0px_0px_#000] dark:focus:shadow-[4px_4px_0px_0px_#fff] transition-all text-sm text-gray-900 dark:text-white">
                    <option value="">All risk levels</option>
                    <option value="low">Low risk</option>
                    <option value="medium">Medium risk</option>
                    <option value="high">High risk</option>
                </select>
            </div>
            <div class="space-y-1">
                <label for="filter-os-select" class="text-xs font-bold text-gray-500 uppercase">Target OS</label>
                <select id="filter-os-select" class="w-full px-3 py-2 bg-white dark:bg-gray-900 border-[3px] border-black dark:border-white font-bold outline-none shadow-[2px_2px_0px_0px_#000] dark:shadow-[2px_2px_0px_0px_#fff] focus:-translate-x-[2px] focus:-translate-y-[2px] focus:shadow-[4px_4px_0px_0px_#000] dark:focus:shadow-[4px_4px_0px_0px_#fff] transition-all text-sm text-gray-900 dark:text-white">
                    <option value="">All OS targets</option>
                    <option value="windows-11">Windows 11</option>
                    <option value="windows-10">Windows 10</option>
                </select>
            </div>
            <div class="space-y-1">
                <label for="filter-view-select" class="text-xs font-bold text-gray-500 uppercase">Layout Density</label>
                <select id="filter-view-select" class="w-full px-3 py-2 bg-white dark:bg-gray-900 border-[3px] border-black dark:border-white font-bold outline-none shadow-[2px_2px_0px_0px_#000] dark:shadow-[2px_2px_0px_0px_#fff] focus:-translate-x-[2px] focus:-translate-y-[2px] focus:shadow-[4px_4px_0px_0px_#000] dark:focus:shadow-[4px_4px_0px_0px_#fff] transition-all text-sm text-gray-900 dark:text-white">
                    <option value="comfortable">Comfortable view</option>
                    <option value="dense">Dense view</option>
                </select>
            </div>
            <button id="filter-clear-button" type="button" class="btn-secondary w-full justify-center !px-3 !py-2 text-sm mt-2">
                <span aria-hidden="true" class="material-icons text-base">refresh</span>
                Reset Filters
            </button>
        </aside>

        <div class="space-y-8">
            <section class="card overflow-hidden !border-l-[12px] !border-l-purple-500" data-brand-section="network">
                <div class="p-6">
                    <div class="flex items-center gap-3.5 mb-2">
                        <span aria-hidden="true" class="material-icons text-purple-500 text-3xl">wifi</span>
                        <h2 class="section-heading">Network Driver Catalog</h2>
                    </div>
                    <p class="text-sm font-semibold text-gray-500 dark:text-gray-400 mb-6">Wi-Fi and ethernet packages with compare-ready metadata and stable URL state.</p>
                    <div id="network-main-drivers" class="grid sm:grid-cols-1 gap-4"></div>
                </div>
            </section>
        </div>
    </div>
</main>

<script is:inline slot="pageScripts">
document.addEventListener('DOMContentLoaded', function() {
    const baseUrl = 'https://raw.githubusercontent.com/BurntToasters/driverWeb-data/main/';
    loadDrivers(baseUrl + 'network-drivers.json', 'network-main-drivers', { family: 'network', channel: 'network', brand: 'network', category: 'Network Drivers', page: '/network' });
});
</script>
</BaseLayout>
