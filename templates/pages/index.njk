{% extends "layouts/base.njk" %}
{% set assetPrefix = '' %}
{% set title = 'DriverHub - Free Driver Downloads for Windows 10 & 11' %}
{% set metaDescription = 'Download the latest NVIDIA, AMD, and Intel graphics drivers, chipset drivers, and more. Free driver downloads for Windows 10 and Windows 11.' %}
{% set metaKeywords = 'driver downloads, NVIDIA drivers, AMD drivers, Intel drivers, chipset drivers, graphics drivers, Windows drivers, GPU drivers' %}
{% set metaAuthor = 'DriverHub' %}
{% set metaRobots = 'index, follow' %}
{% set canonical = 'https://driverhub.win/' %}
{% set showSkipLink = true %}
{% set headerVariant = 'main' %}
{% set navActive = 'home' %}
{% set showSearchButton = true %}
{% set showFavoritesButton = true %}
{% set showDarkModeButton = true %}
{% set showSettings = true %}
{% set footerVariant = 'full' %}
{% set scripts = ['global/favorites.js', 'global/search.js', 'global/darkMode.js', 'global/regionSwitcher.js', 'global/modern.js', 'global/versionInfo.js', 'global/backToTop.js'] %}

{% block metaExtra %}
<meta property="og:type" content="website">
<meta property="og:url" content="https://driverhub.win/">
<meta property="og:title" content="DriverHub - Free Driver Downloads for Windows">
<meta property="og:description" content="Download the latest NVIDIA, AMD, and Intel graphics drivers, chipset drivers, and more.">
<meta property="og:image" content="https://prod.rexxit.net/global/_icons/DH-logo-optim.webp">

<meta property="twitter:card" content="summary_large_image">
<meta property="twitter:url" content="https://driverhub.win/">
<meta property="twitter:title" content="DriverHub - Free Driver Downloads for Windows">
<meta property="twitter:description" content="Download the latest NVIDIA, AMD, and Intel graphics drivers, chipset drivers, and more.">
<meta property="twitter:image" content="https://prod.rexxit.net/global/_icons/DH-logo-optim.webp">
{% endblock %}

{% block headExtra %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "DriverHub",
  "url": "https://driverhub.win",
  "description": "Free driver downloads for Windows including NVIDIA, AMD, and Intel graphics drivers.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://driverhub.win/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>
{% endblock %}

{% block top %}
<div id="status-banner" class="hidden fixed top-0 left-0 right-0 z-50 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 px-4 py-2.5 text-center text-sm font-medium">
    <span id="status-text"></span>
    <button id="dismiss-banner" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/70 dark:text-gray-900/70 hover:text-white dark:hover:text-gray-900 text-xl leading-none" aria-label="Dismiss">&times;</button>
</div>
{% endblock %}

{% block content %}
<main id="main-content" class="flex-1 max-w-6xl mx-auto px-4 md:px-6 w-full">
    <section class="pt-16 pb-12 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white tracking-tight mb-4">Free Windows Driver Downloads</h1>
        <p class="page-subheading max-w-xl mx-auto mb-8">Official drivers from NVIDIA, AMD, and Intel. Every download links directly to the manufacturer.</p>
        <form id="hero-command-form" class="hero-command" role="search" aria-label="Command search">
            <span class="material-icons text-primary-500">terminal</span>
            <input id="hero-command-input" type="text" class="hero-command-input" placeholder="Search: NVIDIA 572.70, Intel Pro, AM5 chipset..." autocomplete="off">
            <kbd class="hero-command-chip">Ctrl+K</kbd>
            <button type="submit" class="btn-primary !px-4 !py-2">
                <span class="material-icons text-lg">search</span>
                Search
            </button>
        </form>

        <div class="mobile-hero-actions">
            <a href="/display" class="btn-primary">
                <span class="material-icons text-lg">download</span>
                Browse Drivers
            </a>
            <button id="hero-search-btn" class="btn-secondary" type="button">
                <span class="material-icons text-lg">search</span>
                Search Drivers
                <kbd class="ml-1 px-1.5 py-0.5 text-xs font-mono bg-gray-200 dark:bg-gray-700 rounded text-gray-500 dark:text-gray-400">Ctrl+K</kbd>
            </button>
        </div>
    </section>

    <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 py-6 border-y border-gray-200 dark:border-gray-800 mb-12">
        <div class="flex items-center gap-2">
            <span class="material-icons text-lg text-primary-500">verified</span>
            <span class="text-sm font-medium text-gray-600 dark:text-gray-400">Direct from manufacturers</span>
        </div>
        <div class="flex items-center gap-2">
            <span class="material-icons text-lg text-primary-500">security</span>
            <span class="text-sm font-medium text-gray-600 dark:text-gray-400">SHA256 verified</span>
        </div>
        <div class="flex items-center gap-2">
            <span class="material-icons text-lg text-primary-500">thumb_up</span>
            <span class="text-sm font-medium text-gray-600 dark:text-gray-400">Community stability ratings</span>
        </div>
    </div>

    <section class="card p-6 mb-10" data-animate>
        <div class="flex items-center gap-3 mb-1">
            <span class="material-icons text-primary-500">auto_fix_high</span>
            <h2 class="section-heading">Recommended Driver</h2>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400 mb-5">Quick-pick the right page by brand, device, and update preference.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <select id="rec-brand" class="px-4 py-3 bg-gray-100 dark:bg-gray-800 rounded-lg border border-transparent focus:border-primary-500 outline-none transition-colors text-gray-900 dark:text-white">
                <option value="nvidia">NVIDIA</option>
                <option value="intel">Intel</option>
                <option value="amd">AMD</option>
            </select>
            <select id="rec-device" class="px-4 py-3 bg-gray-100 dark:bg-gray-800 rounded-lg border border-transparent focus:border-primary-500 outline-none transition-colors text-gray-900 dark:text-white">
                <option value="desktop">Desktop</option>
                <option value="laptop">Laptop</option>
                <option value="chipset">Chipset</option>
            </select>
            <select id="rec-preference" class="px-4 py-3 bg-gray-100 dark:bg-gray-800 rounded-lg border border-transparent focus:border-primary-500 outline-none transition-colors text-gray-900 dark:text-white">
                <option value="latest">Latest</option>
                <option value="stable">Stable</option>
            </select>
            <button id="rec-go" type="button" class="btn-primary justify-center">
                <span class="material-icons text-lg">arrow_forward</span>
                Get Recommendation
            </button>
        </div>
    </section>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 mb-16">
        <a href="/display" class="card-hover group p-5 flex items-start gap-4" data-animate>
            <div class="flex-shrink-0 flex items-center gap-1.5 mt-0.5">
                <img src="https://prod.rexxit.net/drweb/assets/nvidia.jpg" alt="NVIDIA" class="h-7 w-7 rounded object-contain" loading="lazy">
                <img src="https://prod.rexxit.net/drweb/assets/amd.png" alt="AMD" class="h-7 w-7 object-contain" loading="lazy">
                <img src="https://prod.rexxit.net/drweb/assets/intel.png" alt="Intel" class="h-7 w-7 object-contain" loading="lazy">
            </div>
            <div class="flex-1 min-w-0">
                <h2 class="section-heading mb-1 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">Graphics Drivers</h2>
                <p class="text-sm text-gray-500 dark:text-gray-400">NVIDIA, AMD, and Intel GPU drivers for desktop and laptop</p>
                <div class="mt-3 flex flex-wrap items-center gap-2">
                    <span class="trust-chip"><span class="material-icons text-[14px]">verified</span>Source: Official</span>
                    <span class="trust-chip"><span class="material-icons text-[14px]">security</span>SHA256 available</span>
                </div>
            </div>
            <span class="material-icons text-gray-300 dark:text-gray-600 group-hover:text-primary-500 transition-colors mt-1">arrow_forward</span>
        </a>

        <a href="/chipset" class="card-hover group p-5 flex items-start gap-4" data-animate>
            <div class="flex-shrink-0 flex items-center gap-1.5 mt-0.5">
                <img src="https://prod.rexxit.net/drweb/assets/intel.png" alt="Intel" class="h-7 w-7 object-contain" loading="lazy">
                <img src="https://prod.rexxit.net/drweb/assets/amdryzen.png" alt="AMD Ryzen" class="h-7 w-7 object-contain" loading="lazy">
            </div>
            <div class="flex-1 min-w-0">
                <h2 class="section-heading mb-1 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">Chipset Drivers</h2>
                <p class="text-sm text-gray-500 dark:text-gray-400">Intel and AMD motherboard chipset drivers</p>
                <div class="mt-3 flex flex-wrap items-center gap-2">
                    <span class="trust-chip"><span class="material-icons text-[14px]">memory</span>Intel + AMD</span>
                    <span class="trust-chip"><span class="material-icons text-[14px]">schedule</span>Frequently updated</span>
                </div>
            </div>
            <span class="material-icons text-gray-300 dark:text-gray-600 group-hover:text-primary-500 transition-colors mt-1">arrow_forward</span>
        </a>

        <a href="/audio" class="card-hover group p-5 flex items-start gap-4" data-animate>
            <div class="flex-shrink-0 mt-0.5">
                <img src="https://prod.rexxit.net/drweb/assets/realtek.png" alt="Realtek" class="h-7 w-7 object-contain" loading="lazy">
            </div>
            <div class="flex-1 min-w-0">
                <h2 class="section-heading mb-1">Audio Drivers</h2>
                <p class="text-sm text-gray-500 dark:text-gray-400">Preview page with roadmap status and notify-me option</p>
                <div class="mt-3 flex items-center gap-2">
                    <span class="trust-chip"><span class="material-icons text-[14px]">schedule</span>ETA: v5.x</span>
                    <span class="trust-chip"><span class="material-icons text-[14px]">notifications</span>Notify me</span>
                </div>
            </div>
            <span class="px-2.5 py-1 text-xs font-medium bg-primary-50 dark:bg-primary-900/30 text-primary-600 dark:text-primary-300 rounded-md whitespace-nowrap">Preview</span>
        </a>

        <a href="/network" class="card-hover group p-5 flex items-start gap-4" data-animate>
            <div class="flex-shrink-0 mt-0.5">
                <span class="material-icons text-2xl text-gray-400">wifi</span>
            </div>
            <div class="flex-1 min-w-0">
                <h2 class="section-heading mb-1">Network Drivers</h2>
                <p class="text-sm text-gray-500 dark:text-gray-400">Preview page with progress tracker and notify-me option</p>
                <div class="mt-3 flex items-center gap-2">
                    <span class="trust-chip"><span class="material-icons text-[14px]">schedule</span>ETA: v5.x</span>
                    <span class="trust-chip"><span class="material-icons text-[14px]">notifications</span>Notify me</span>
                </div>
            </div>
            <span class="px-2.5 py-1 text-xs font-medium bg-primary-50 dark:bg-primary-900/30 text-primary-600 dark:text-primary-300 rounded-md whitespace-nowrap">Preview</span>
        </a>

        <a href="/contact" class="card-hover group p-5 flex items-start gap-4" data-animate>
            <div class="flex-shrink-0 mt-0.5">
                <span class="material-icons text-2xl text-primary-500">mail_outline</span>
            </div>
            <div class="flex-1 min-w-0">
                <h2 class="section-heading mb-1 group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">Contact</h2>
                <p class="text-sm text-gray-500 dark:text-gray-400">Questions, feedback, or suggestions?</p>
            </div>
            <span class="material-icons text-gray-300 dark:text-gray-600 group-hover:text-primary-500 transition-colors mt-1">arrow_forward</span>
        </a>
    </div>
</main>
{% endblock %}

{% block pageScripts %}
<script>
const STATUS_BANNER_ENABLED = true;
const STATUS_BANNER_TEXT = "Welcome to DriverHub v5! Questions or feedback? Contact us!";
const STATUS_BANNER_KEY = "statusBannerDismissed_" + STATUS_BANNER_TEXT;

document.addEventListener('DOMContentLoaded', function() {
    const banner = document.getElementById('status-banner');
    const text = document.getElementById('status-text');
    const dismissBtn = document.getElementById('dismiss-banner');
    const dismissed = localStorage.getItem(STATUS_BANNER_KEY);

    if (STATUS_BANNER_ENABLED && !dismissed && banner && text) {
        banner.classList.remove('hidden');
        banner.classList.add('flex');
        text.textContent = STATUS_BANNER_TEXT;
    }

    if (dismissBtn && banner) {
        dismissBtn.addEventListener('click', function() {
            banner.classList.add('hidden');
            banner.classList.remove('flex');
            localStorage.setItem(STATUS_BANNER_KEY, '1');
        });
    }

    const heroSearchBtn = document.getElementById('hero-search-btn');
    if (heroSearchBtn && typeof SearchModule !== 'undefined') {
        heroSearchBtn.addEventListener('click', () => SearchModule.open());
    } else if (heroSearchBtn) {
        heroSearchBtn.addEventListener('click', () => {
            const searchBtn = document.getElementById('global-search-btn');
            if (searchBtn) searchBtn.click();
        });
    }

    const heroCommandForm = document.getElementById('hero-command-form');
    const heroCommandInput = document.getElementById('hero-command-input');
    if (heroCommandForm && heroCommandInput) {
        heroCommandForm.addEventListener('submit', function(event) {
            event.preventDefault();
            const query = heroCommandInput.value.trim();
            if (!query) return;

            if (typeof SearchModule !== 'undefined' && typeof SearchModule.openWithQuery === 'function') {
                SearchModule.openWithQuery(query);
            } else {
                window.location.href = `/display?q=${encodeURIComponent(query)}`;
            }
        });
    }

    const recBrand = document.getElementById('rec-brand');
    const recDevice = document.getElementById('rec-device');
    const recPreference = document.getElementById('rec-preference');
    const recGo = document.getElementById('rec-go');

    if (recGo && recBrand && recDevice && recPreference) {
        recGo.addEventListener('click', function() {
            let brand = recBrand.value;
            const device = recDevice.value;
            const preference = recPreference.value;

            let targetPath = '/display';
            if (device === 'laptop') {
                targetPath = brand === 'intel' ? '/display' : '/display/laptop';
            } else if (device === 'chipset') {
                if (brand === 'nvidia') {
                    brand = 'intel';
                }
                targetPath = '/chipset';
            }

            const params = new URLSearchParams();
            params.set('brand', brand);
            if (device !== 'chipset') {
                params.set('filter', preference === 'stable' ? 'stable' : 'all');
            }

            window.location.href = `${targetPath}?${params.toString()}`;
        });
    }
});
</script>
{% endblock %}
