{% extends "layouts/base.njk" %}
{% set assetPrefix = '' %}
{% set title = 'Audio Drivers Preview | DriverHub' %}
{% set metaDescription = 'Audio driver preview for DriverHub. Track progress and request launch notifications for Realtek and related audio drivers.' %}
{% set metaRobots = 'index, follow' %}
{% set canonical = 'https://driverhub.win/audio' %}
{% set showSkipLink = true %}
{% set headerVariant = 'main' %}
{% set navActive = 'audio' %}
{% set showSearchButton = true %}
{% set showFavoritesButton = true %}
{% set showDarkModeButton = true %}
{% set showSettings = true %}
{% set footerVariant = 'full' %}
{% set scripts = ['global/favorites.js', 'global/search.js', 'global/darkMode.js', 'global/regionSwitcher.js', 'global/modern.js', 'global/versionInfo.js', 'global/backToTop.js'] %}

{% block content %}
<main id="main-content" class="flex-1 max-w-6xl mx-auto px-4 md:px-6 py-12 w-full">
    <div class="mb-8">
        <h1 class="page-heading mb-2">Audio Drivers Preview</h1>
        <p class="page-subheading">Realtek and other Windows audio drivers are planned for v5.x. Follow progress and get notified.</p>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">
        <section class="lg:col-span-2 card p-6" data-animate>
            <div class="flex items-center gap-2 mb-4">
                <span class="material-icons text-primary-500">headphones</span>
                <h2 class="section-heading">Roadmap Status</h2>
            </div>
            <div class="space-y-3 text-sm">
                <div class="flex items-center justify-between gap-3 p-3 rounded-lg bg-gray-100 dark:bg-gray-800">
                    <span class="text-gray-700 dark:text-gray-300">Data schema finalized</span>
                    <span class="px-2 py-0.5 rounded text-xs font-semibold bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300">Done</span>
                </div>
                <div class="flex items-center justify-between gap-3 p-3 rounded-lg bg-gray-100 dark:bg-gray-800">
                    <span class="text-gray-700 dark:text-gray-300">Vendor source validation</span>
                    <span class="px-2 py-0.5 rounded text-xs font-semibold bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300">In progress</span>
                </div>
                <div class="flex items-center justify-between gap-3 p-3 rounded-lg bg-gray-100 dark:bg-gray-800">
                    <span class="text-gray-700 dark:text-gray-300">Public listing launch</span>
                    <span class="px-2 py-0.5 rounded text-xs font-semibold bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300">ETA v5.x</span>
                </div>
            </div>
            <div class="mt-5 flex flex-wrap gap-2">
                <span class="trust-chip"><span class="material-icons text-[14px]">schedule</span>ETA: v5.x</span>
                <span class="trust-chip"><span class="material-icons text-[14px]">verified</span>Official vendor links only</span>
            </div>
        </section>

        <aside class="card p-6" data-animate>
            <h2 class="section-heading mb-2">Notify Me</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Save your email locally and jump to contact with a pre-filled request.</p>

            <label for="audio-notify-email" class="sr-only">Email</label>
            <input id="audio-notify-email" type="email" class="w-full px-4 py-3 bg-gray-100 dark:bg-gray-800 rounded-lg border border-transparent focus:border-primary-500 outline-none transition-colors text-gray-900 dark:text-white" placeholder="you@example.com">

            <div class="mt-3 grid grid-cols-1 gap-2">
                <button id="audio-save-notify" type="button" class="btn-primary justify-center">
                    <span class="material-icons text-lg">notifications</span>
                    Save Notification Request
                </button>
                <a id="audio-contact-link" href="/contact" class="btn-secondary justify-center">
                    <span class="material-icons text-lg">mail_outline</span>
                    Contact About Audio Launch
                </a>
            </div>

            <p id="audio-notify-status" class="text-xs text-gray-500 mt-3" aria-live="polite"></p>
        </aside>
    </div>
</main>
{% endblock %}

{% block pageScripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const storageKey = 'driverhub_notify_audio';
    const input = document.getElementById('audio-notify-email');
    const saveButton = document.getElementById('audio-save-notify');
    const status = document.getElementById('audio-notify-status');
    const contactLink = document.getElementById('audio-contact-link');

    function updateContactLink(email) {
        const params = new URLSearchParams();
        params.set('topic', 'audio-launch');
        if (email) {
            params.set('email', email);
        }
        contactLink.href = `/contact?${params.toString()}`;
    }

    const storedEmail = localStorage.getItem(storageKey) || '';
    if (storedEmail && input) {
        input.value = storedEmail;
    }
    updateContactLink(storedEmail);

    if (saveButton && input) {
        saveButton.addEventListener('click', function() {
            const email = input.value.trim();
            if (!email || !email.includes('@')) {
                status.textContent = 'Enter a valid email address.';
                return;
            }
            localStorage.setItem(storageKey, email);
            updateContactLink(email);
            status.textContent = 'Saved locally. Use the contact button to send your request.';
        });
    }
});
</script>
{% endblock %}
